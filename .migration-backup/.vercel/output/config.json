{
  "version": 3,
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/handler"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "overrides": {
    "assets/**": {
      "headers": {
        "cache-control": "public,max-age=31536000,immutable"
      }
    }
  }
}