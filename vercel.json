{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "pnpm --filter @workspace/olyxee-admin run build:vercel",
  "installCommand": "pnpm install",
  "outputDirectory": "artifacts/olyxee-admin/dist/public",
  "framework": null,
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
