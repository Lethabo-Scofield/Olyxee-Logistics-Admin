# =============================================================================
# Olyxee Admin — environment variables
# =============================================================================
#
# Copy this file to `.env` (and configure each Vercel/Replit environment) and
# fill in the values from your Supabase project.

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# Postgres connection string. In production this should be your Supabase
# Postgres URL. On Vercel (or any serverless host) you MUST use the pooled
# connection on port 6543 — direct connections (port 5432) exhaust quickly
# under cold-start patterns and will cause intermittent 5xx errors.
DATABASE_URL=

# -----------------------------------------------------------------------------
# Supabase Auth
# -----------------------------------------------------------------------------
# Project URL — Supabase dashboard → Project Settings → API → Project URL
VITE_SUPABASE_URL=

# Public anon key — same page → Project API keys → anon/public
# Safe to embed in the browser bundle.
VITE_SUPABASE_ANON_KEY=

# Service role key — same page → service_role
# DO NOT expose to the browser. Used by the API server to verify user JWTs
# and (optionally) perform admin operations. Falls back to the anon key
# when omitted, but admin operations will fail.
SUPABASE_SERVICE_ROLE_KEY=
