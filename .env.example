# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string.
# Recommended providers: Neon (neon.tech), Supabase, Railway, PlanetScale.
# Example: postgres://user:password@host/dbname?sslmode=require
DATABASE_URL=

# ─── Clerk Authentication ─────────────────────────────────────────────────────
# Get these from your Clerk dashboard → API Keys.
# Use PRODUCTION keys for Vercel (not dev keys — dev keys show a warning banner).
CLERK_PUBLISHABLE_KEY=pk_live_...
CLERK_SECRET_KEY=sk_live_...

# ─── Frontend (Vite VITE_ prefix = exposed to browser) ───────────────────────
VITE_CLERK_PUBLISHABLE_KEY=pk_live_...

# Clerk proxy URL — routes Clerk's Frontend API through your own domain.
# Set to:  https://<your-vercel-domain>/api/__clerk
# This removes the Clerk subdomain requirement and enables custom domains.
VITE_CLERK_PROXY_URL=https://your-app.vercel.app/api/__clerk

# ─── Email (Resend) ──────────────────────────────────────────────────────────
# Get from resend.com → API Keys. Required for customer email notifications.
RESEND_API_KEY=re_...

# ─── Optional ────────────────────────────────────────────────────────────────
# Log level: trace | debug | info | warn | error | fatal  (default: info)
LOG_LEVEL=info

# Session secret for signed cookies (generate with: openssl rand -hex 32)
SESSION_SECRET=
